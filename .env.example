# ─── Supabase (required for production persistence) ───────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── AI Provider (leave blank to use built-in mock adapter) ───────────────────
# Options: openai | anthropic | gemini
NEXT_PUBLIC_AI_PROVIDER=

# Server-side AI keys (used by /api/ai route — planned for v0.3)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Observability (optional) ─────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=

# ─── Email (optional, planned for v0.3) ───────────────────────────────────────
RESEND_API_KEY=
