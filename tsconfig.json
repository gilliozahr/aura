{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@aura/types": ["./src/lib/types.ts"],
      "@aura/ai": ["./packages/ai/index.ts"],
      "@aura/agents": ["./packages/agents/index.ts"],
      "@aura/recommendation": ["./packages/recommendation/index.ts"],
      "@aura/memory": ["./packages/memory/index.ts"],
      "@aura/storage": ["./packages/storage/index.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
